{
  "manifest_version": 3,
  "name": "TabPilot",
  "version": "0.1.0",
  "description": "작업 중인 탭은 보호하고, 오래 사용하지 않은 탭만 안전하게 휴면 처리해 Chrome 메모리를 관리합니다.",
  "minimum_chrome_version": "121",
  "incognito": "not_allowed",
  "permissions": ["tabs", "storage", "system.memory", "alarms"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "TabPilot",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "options_page": "options.html"
}
